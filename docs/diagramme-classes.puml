@startuml Diagramme de classes - DarQuran
!theme plain
skinparam backgroundColor #FEFEFE
skinparam roundCorner 8
skinparam classAttributeIconSize 0
skinparam classFontSize 12
skinparam defaultFontName Arial
skinparam packageStyle rectangle
skinparam linetype ortho

title Diagramme de classes - Domaine DarQuran\n(mise en page propre, conventions UML)

' ========== PACKAGE UTILISATEURS ==========
package "Utilisateurs" as pkg_users #E8F4FD {
  abstract class Utilisateur {
    - id : String
    - nom : String
    - prenom : String
    - email : String
    - telephone : String
    - photoUrl : String
    - dateNaissance : LocalDate
    - role : Role
    - section : Section
    - createdAt : LocalDateTime
    --
    + getUsername() : String
    + getPassword() : String
    + getAuthorities() : Collection
    + isEnabled() : boolean
  }

  class Enseignant {
  }

  class Eleve {
  }

  class Admin {
  }

  class SuperAdmin {
  }

  Utilisateur <|-- Enseignant
  Utilisateur <|-- Eleve
  Utilisateur <|-- Admin
  Utilisateur <|-- SuperAdmin
}

' ========== PACKAGE LIVE ==========
package "Bascule Live" as pkg_live #FFF4E6 {
  class SessionLive {
    - id : String
    - title : String
    - description : String
    - streamKey : String
    - hlsPlaybackUrl : String
    - status : LiveSessionStatus
    - accessType : LiveAccessType
    - adaptiveQualityEnabled : boolean
    - recordingEnabled : boolean
    - recordingUrl : String
    - scheduledStartAt : LocalDateTime
    - scheduledEndAt : LocalDateTime
    - startedAt : LocalDateTime
    - endedAt : LocalDateTime
    - section : Section
    - createdAt : LocalDateTime
    - updatedAt : LocalDateTime
    --
    + onCreate() : void
    + onUpdate() : void
  }

  class CommentaireLive {
    - id : String
    - content : String
    - authorDisplayName : String
    - createdAt : LocalDateTime
    --
    + onCreate() : void
  }

  SessionLive "1" *-- "0..*" CommentaireLive : contient
  Utilisateur "1" o-- "0..*" SessionLive : anime
  Utilisateur "0..1" o-- "0..*" CommentaireLive : auteur
}

' ========== PACKAGE COURS ==========
package "Cours et contenus" as pkg_course #E8F5E9 {
  class Cours {
    - id : String
    - title : String
    - slug : String
    - description : String
    - miniature : String
    - isPublic : boolean
    - status : CourseStatus
    - level : CourseLevel
    - createdAt : LocalDateTime
    - updatedAt : LocalDateTime
    --
    + onCreate() : void
    + onUpdate() : void
  }

  class Lecon {
    - id : String
    - title : String
    - description : String
    - orderIndex : Integer
    - createdAt : LocalDateTime
    - updatedAt : LocalDateTime
    --
    + onCreate() : void
    + onUpdate() : void
  }

  class Ressource {
    - id : String
    - name : String
    - fileUrl : String
    - type : ResourceType
    - size : Long
    - createdAt : LocalDateTime
    --
    + onCreate() : void
  }

  Cours "1" *-- "0..*" Lecon : contient
  Lecon "1" *-- "0..*" Ressource : contient
}

' ========== PACKAGE ÉCOLE ==========
package "École et planning" as pkg_school #F3E5F5 {
  class Salle {
    - id : String
    - name : String
    - section : Section
    - capacity : Integer
  }

  class CreneauHoraire {
    - id : String
    - dayOfWeek : Integer
    - startTime : LocalTime
    - endTime : LocalTime
  }

  class Inscription {
    - id : String
    - enrolledAt : LocalDateTime
    - active : Boolean
  }

  class NoteEleve {
    - id : String
    - value : Double
    - gradeDate : LocalDate
    - comment : String
    - createdAt : LocalDateTime
    --
    + onCreate() : void
  }

  class AbsenceEleve {
    - id : String
    - date : LocalDate
    - status : AbsenceStatus
    - justificationText : String
    - createdAt : LocalDateTime
    --
    + onCreate() : void
  }

  Enseignant "0..1" o-- "0..*" Salle : responsable
  Salle "1" o-- "0..*" CreneauHoraire : planifiée
  Cours "1" o-- "0..*" CreneauHoraire : dispensé
  Enseignant "1" o-- "0..*" CreneauHoraire : assure
  Eleve "1" o-- "0..*" Inscription : inscrit
  Cours "1" o-- "0..*" Inscription : reçoit
  Eleve "1" o-- "0..*" NoteEleve : reçoit
  Cours "1" o-- "0..*" NoteEleve : évalué
  Enseignant "1" o-- "0..*" NoteEleve : attribue
  Eleve "1" o-- "0..*" AbsenceEleve : concerné
  CreneauHoraire "1" o-- "0..*" AbsenceEleve : liée
}

' ========== RELATIONS CROISÉES (éviter encombrement) ==========
' SessionLive connaît son animateur (User) déjà dans pkg_live
' CreneauHoraire lie Salle, Cours, Enseignant déjà dans pkg_school

' ========== ENUMS (en bas pour lisibilité) ==========
enum Role {
  SUPER_ADMIN
  ADMIN_SECTION
  ENSEIGNANT
  ELEVE
  PARENT
  PUBLIC
}

enum Section {
  HOMME
  FEMME
}

enum LiveSessionStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
  RECORDING
}

enum LiveAccessType {
  INTERNAL
  EXTERNAL
}

Utilisateur ..> Role : utilise
Utilisateur ..> Section : utilise
SessionLive ..> LiveSessionStatus : utilise
SessionLive ..> LiveAccessType : utilise
SessionLive ..> Section : utilise
Salle ..> Section : utilise
enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum ResourceType {
  TEXT
  PDF
  VIDEO
}

enum AbsenceStatus {
  JUSTIFIED
  UNJUSTIFIED
  PENDING
}

Cours ..> CourseStatus : utilise
Cours ..> CourseLevel : utilise
Ressource ..> ResourceType : utilise
AbsenceEleve ..> AbsenceStatus : utilise

@enduml
